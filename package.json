{
  "name": "@seecost/tracker",
  "version": "0.1.2",
  "description": "Server-side SDK with a setup CLI for tracking LLM API usage costs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ronpaou/seecost-tracker.git"
  },
  "homepage": "https://github.com/ronpaou/seecost-tracker#readme",
  "bugs": {
    "url": "https://github.com/ronpaou/seecost-tracker/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tracker": {
      "types": "./dist/tracker.d.ts",
      "import": "./dist/tracker.js",
      "default": "./dist/tracker.js"
    }
  },
  "files": [
    "dist",
    "model-aliases.json",
    "pricing.json",
    "README.md"
  ],
  "bin": {
    "seecost": "dist/cli.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm test",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "npm run build"
  },
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "cost-tracking",
    "observability"
  ],
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.13",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
